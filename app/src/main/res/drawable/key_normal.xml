<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2A3A6A" />
            <corners android:radius="5dp" />
            <stroke android:width="1dp" android:color="#44AAFF" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#141828" />
            <corners android:radius="5dp" />
            <stroke android:width="1dp" android:color="#1E2840" />
        </shape>
    </item>
</selector>
