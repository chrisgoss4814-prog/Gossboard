<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2A1A4A" />
            <corners android:radius="5dp" />
            <stroke android:width="1dp" android:color="#CC44FF" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="#1A0A3A" />
            <corners android:radius="5dp" />
            <stroke android:width="1dp" android:color="#9922FF" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0E0618" />
            <corners android:radius="5dp" />
            <stroke android:width="1dp" android:color="#440088" />
        </shape>
    </item>
</selector>
